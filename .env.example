# QuestCanvas v1 uses a Canvas personal access token locally.

# ─── Canvas LMS ───────────────────────────────────────────
CANVAS_BASE_URL=https://your-institution.instructure.com
CANVAS_TOKEN=

# ─── Local Storage ────────────────────────────────────────
# Optional override for local metadata/index storage.
QUESTCANVAS_DATA_DIR=~/.local/share/questcanvas
